  fallbackInteractionText: Learn routines
  dialogueVariants:
  - conditions:
      requiredKnowledgeIds: []
      blockedKnowledgeIds:
      - bunny-loop-hint
      requiredCompletedTaskIds: []
      requiredIncompleteTaskIds: []
    sequence:
      sequenceId: bunny-test-intro
      interactionText: Learn routines
      speakerName: Bunny
      lines:
      - speakerName: Bunny
        body: You're awake in the same morning too, aren't you?
      - speakerName: Bunny
        body: I tucked some seeds near the old path before the light turns warm.
          Keep that in mind when the day folds over.
      knowledgeIdsToLearn:
      - bunny-loop-hint
      taskIdsToComplete: []
      onSequenceCompleted:
        m_PersistentCalls:
          m_Calls: []
  - conditions:
