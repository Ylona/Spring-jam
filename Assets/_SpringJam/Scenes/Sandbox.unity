MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1089371788}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 6d7a59ce72d9b4e4487354f8429e367a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcInteractable
  interactionText: Talk
  knowledgeIdsToLearn: []
  taskIdsToComplete:
  - learn-routines
  fallbackInteractionText: Learn routines
  dialogueVariants:
  - conditions:
      requiredKnowledgeIds: []
      blockedKnowledgeIds:
      - bunny-loop-hint
      requiredCompletedTaskIds: []
      requiredIncompleteTaskIds: []
    sequence:
      sequenceId: bunny-test-intro
      interactionText: Learn routines
      speakerName: Bunny
      lines:
      - speakerName: Bunny
        body: You're awake in the same morning too, aren't you?
      - speakerName: Bunny
        body: I tucked the cherry basket near the old path before the light turns
          warm.
      - speakerName: Bunny
        body: 'For the meadow, remember this: Smallest first, tallest last: snowdrop,
          crocus, tulip.'
      knowledgeIdsToLearn:
      - bunny-loop-hint
      taskIdsToComplete: []
      onSequenceCompleted:
        m_PersistentCalls:
          m_Calls: []
  - conditions:
      requiredKnowledgeIds:
      - bunny-loop-hint
      blockedKnowledgeIds: []
      requiredCompletedTaskIds: []
      requiredIncompleteTaskIds: []
    sequence:
      sequenceId: bunny-test-reminder
      interactionText: Learn routines
      speakerName: Bunny
      lines:
      - speakerName: Bunny
        body: There, you remembered.
      - speakerName: Bunny
        body: Old path early for the basket.
      - speakerName: Bunny
        body: 'Then wake the meadow the same way: Smallest first, tallest last: snowdrop,
          crocus, tulip.'
      knowledgeIdsToLearn: []
      taskIdsToComplete: []
      onSequenceCompleted:
        m_PersistentCalls:
          m_Calls: []
  onNpcTalkedTo:
    m_PersistentCalls:
      m_Calls: []
