      interactionText: Learn routines
      speakerName: Bunny
      lines:
      - speakerName: Bunny
        body: There, you remembered.
      - speakerName: Bunny
        body: Try the old path early and the valley might answer back a little faster.
      knowledgeIdsToLearn: []
      taskIdsToComplete: []
